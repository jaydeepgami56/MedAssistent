# MedAssist AI - Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic Claude API Key
# Obtain from: https://console.anthropic.com/
# Used by: All agents for clinical reasoning and NLP
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# Claude Model Selection
# Options: claude-sonnet-4-20250514 (recommended), claude-opus-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# =============================================================================
# OPTIONAL API KEYS (Recommended for Production)
# =============================================================================

# NCBI PubMed API Key (also known as PUBMED_API_KEY)
# Obtain from: https://www.ncbi.nlm.nih.gov/account/
# Used by: Research Agent for literature searches
# Benefit: Increases rate limit from 3/sec to 10/sec
# Cost: FREE
NCBI_API_KEY=
PUBMED_API_KEY=

# DrugBank API Key
# Obtain from: https://go.drugbank.com/ (requires academic/institutional access)
# Used by: Pharmacy Agent for drug interaction lookups
# Note: Can use mock data for MVP development
# Cost: FREE for academic use, paid for commercial
DRUGBANK_API_KEY=

# =============================================================================
# LM STUDIO CONFIGURATION (Local AI Models for HIPAA Compliance)
# =============================================================================

# LM Studio API Base URL
# Default: http://127.0.0.1:1234/v1
# Used for: Local, HIPAA-safe inference with PHI data
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# MedImageInsight Model Directory
# Path to MedImageInsight model files (downloaded from HuggingFace)
MEDIMAGEINSIGHT_MODEL_DIR=./models/medimageinsight

# =============================================================================
# DATABASE CONFIGURATION (Will be set up in later phases)
# =============================================================================

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_DB=medassist
POSTGRES_USER=medassist
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}
QDRANT_API_KEY=

# =============================================================================
# EXTERNAL SERVICES (Will be configured in later phases)
# =============================================================================

# Orthanc DICOM Server
ORTHANC_HOST=localhost
ORTHANC_PORT=8042
ORTHANC_URL=http://${ORTHANC_HOST}:${ORTHANC_PORT}
ORTHANC_USER=
ORTHANC_PASSWORD=

# FHIR Server (Epic/Cerner)
FHIR_BASE_URL=
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# RxNorm Drug Database API
RXNORM_API_URL=https://rxnav.nlm.nih.gov/REST

# Azure Active Directory (OAuth2)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=development

# Backend API
API_HOST=localhost
API_PORT=8000

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# =============================================================================
# SECURITY & COMPLIANCE
# =============================================================================

# Encryption Keys (Generate secure random keys for production)
# Use: openssl rand -base64 32
ENCRYPTION_KEY=

# JWT Secret (Generate secure random key for production)
JWT_SECRET=

# Session Secret
SESSION_SECRET=

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Audit Log Path
AUDIT_LOG_PATH=./logs/audit.log

# =============================================================================
# FEATURE FLAGS (For MVP development)
# =============================================================================

# Use mock data for DrugBank if API key not available
USE_MOCK_DRUGBANK=true

# Use mock data for FHIR if not connected to real EHR
USE_MOCK_FHIR=true

# Enable/disable specific agents during development
ENABLE_TRIAGE_AGENT=true
ENABLE_RADIOLOGY_AGENT=true
ENABLE_DIAGNOSTIC_AGENT=true
ENABLE_PHARMACY_AGENT=true
ENABLE_MONITORING_AGENT=true
ENABLE_DOCUMENTATION_AGENT=true
ENABLE_RESEARCH_AGENT=true
ENABLE_COORDINATOR_AGENT=true
